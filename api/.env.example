# Example environment variables for FocusBro API (Cloudflare Worker bindings)
# Do NOT commit real secrets; keep them in your Cloudflare account or CI secret store.

# Cloudflare bindings (example names used in wrangler.toml)
DB_BINDING=DB
KV_BINDING=KV_CACHE

# JWT
JWT_SECRET=your_jwt_secret_here

# Database / D1 (if used locally)
DATABASE_URL=sqlite://path/to/db.sqlite

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_yyy

# API origin used for redirects
API_ORIGIN=https://your-domain.example

# Debug
DEBUG=false
# FocusBro API Configuration
# Copy this file to .env and fill in your actual values

# ════════════════════════════════════════════════════════════
# REQUIRED SECRETS (NEVER commit to git)
# ════════════════════════════════════════════════════════════

# JWT signing secret - generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_change_in_production

# Stripe webhook signing secret (from Stripe dashboard)
# https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Stripe API keys (from Stripe dashboard)
# https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx

# ════════════════════════════════════════════════════════════
# OPTIONAL CONFIGURATION
# ════════════════════════════════════════════════════════════

# Environment (development, staging, production)
ENVIRONMENT=production

# Enable debug logging (true/false)
DEBUG=false

# Allowed origins for CORS
ALLOWED_ORIGINS=https://focusbro.net,https://www.focusbro.net

# ════════════════════════════════════════════════════════════
# CLOUDFLARE BINDINGS (auto-configured via wrangler.toml)
# ════════════════════════════════════════════════════════════

# Database binding - configured in wrangler.toml
# DB is accessible as env.DB

# KV namespace for rate limiting and caching - configured in wrangler.toml
# KV is accessible as env.KV
